<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="18dp">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">


            <LinearLayout
                android:id="@+id/account_container_settings_fragment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:gravity="start"
                    android:text="Account"
                    android:textColor="@color/section_title"
                    android:textSize="16sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_transparent_stroke_primary"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_edit_profile_settings_fragment"
                            style="@style/Widget.Material3.Button.IconButton.Outlined"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="Edit Profile"
                            android:textAlignment="textStart"
                            android:textColor="@color/title"
                            android:textSize="16sp"
                            app:icon="@drawable/ic_profile"
                            app:iconPadding="12dp"
                            app:iconSize="16dp"
                            app:iconTint="@color/icon"
                            app:strokeWidth="0dp" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="12dp"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon" />

                    </RelativeLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_change_pass_settings_fragment"
                            style="@style/Widget.Material3.Button.IconButton.Outlined"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Change Password"
                            android:textAlignment="textStart"
                            android:textColor="@color/title"
                            android:textSize="16sp"
                            app:icon="@drawable/ic_lock"
                            app:iconPadding="12dp"
                            app:iconSize="16dp"
                            app:iconTint="@color/icon"
                            app:strokeWidth="0dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_logout_settings_fragment"
                        style="@style/Widget.Material3.Button.IconButton.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="12dp"
                        android:text="Log Out"
                        android:textAlignment="textStart"
                        android:textColor="@color/alert"
                        android:textSize="16sp"
                        app:cornerRadius="1dp"
                        app:icon="@drawable/ic_logout"
                        app:iconPadding="10dp"
                        app:iconSize="16dp"
                        app:iconTint="@color/alert"
                        app:strokeWidth="0dp" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/appearance_container_settings_fragment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:gravity="start"
                    android:text="Appearance"
                    android:textColor="@color/section_title"
                    android:textSize="16sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_transparent_stroke_primary"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <RelativeLayout
                        android:id="@+id/dark_mode_container_settings_fragment"
                        android:layout_width="match_parent"
                        android:layout_height="50dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_dark_mode_setings_fragment"
                            style="@style/Widget.Material3.Button.IconButton.Outlined"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false"
                            android:text="Dark Mode"
                            android:textAlignment="textStart"
                            android:textColor="@color/title"
                            android:textSize="16sp"
                            app:icon="@drawable/ic_moon"
                            app:iconPadding="12dp"
                            app:iconSize="16dp"
                            app:iconTint="@color/icon"
                            app:strokeWidth="0dp" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/dark_mode_switch_settings_fragment"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="12dp"
                            android:checked="true"
                            app:thumbIcon="@drawable/ic_moon"
                            app:thumbIconSize="22dp"
                            app:thumbIconTint="@color/switch_thumb"
                            app:thumbTint="@color/transparent"
                            app:trackDecorationTint="@color/switch_track"
                            app:trackTint="@color/switch_track" />

                    </RelativeLayout>

                    <RelativeLayout
                        android:id="@+id/accent_color_container_settings_fragment"
                        android:layout_width="match_parent"
                        android:layout_height="50dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_accent_color_settings_fragment"
                            style="@style/Widget.Material3.Button.IconButton.Outlined"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Accent Color"
                            android:textAlignment="textStart"
                            android:textColor="@color/title"
                            android:textSize="16sp"
                            app:icon="@drawable/ic_pallete"
                            app:iconPadding="12dp"
                            app:iconSize="16dp"
                            app:iconTint="@color/icon"
                            app:strokeWidth="0dp" />

                        <TextView
                            android:id="@+id/accent_color_text_tint_settings_fragment"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginHorizontal="6dp"
                            android:layout_toStartOf="@id/accent_color_arrow_settings_fragment"
                            android:text="Space Purple"
                            android:textColor="@color/body"
                            android:textSize="14sp" />

                        <ImageView
                            android:id="@+id/accent_color_arrow_settings_fragment"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="12dp"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon" />

                    </RelativeLayout>

                </LinearLayout>


            </LinearLayout>

            <LinearLayout
                android:id="@+id/help_container_settings_fragment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:gravity="start"
                    android:text="Help and Support"
                    android:textColor="@color/section_title"
                    android:textSize="16sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_transparent_stroke_primary"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:clickable="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_faq_settings_fragment"
                            style="@style/Widget.Material3.Button.IconButton.Outlined"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="FAQ"
                            android:textAlignment="textStart"
                            android:textColor="@color/title"
                            android:textSize="16sp"
                            app:icon="@drawable/ic_help"
                            app:iconPadding="12dp"
                            app:iconSize="20dp"
                            app:iconTint="@color/icon"
                            app:strokeWidth="0dp" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="12dp"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon" />

                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_about_settings_fragment"
                            style="@style/Widget.Material3.Button.IconButton.Outlined"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="About"
                            android:textAlignment="textStart"
                            android:textColor="@color/title"
                            android:textSize="16sp"
                            app:icon="@drawable/ic_info"
                            app:iconPadding="12dp"
                            app:iconSize="20dp"
                            app:iconTint="@color/icon"
                            app:strokeWidth="0dp" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="12dp"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon" />

                    </RelativeLayout>

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:gravity="center"
                android:text="Astryx v1.0.0"
                android:textColor="@color/body"
                android:textSize="12sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="© 2026 Astryx. All rights reserved."
                android:textColor="@color/body"
                android:textSize="12sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="50dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.appcompat.widget.LinearLayoutCompat>