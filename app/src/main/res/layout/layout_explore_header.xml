<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="65dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_centerVertical="true"
        android:layout_marginHorizontal="10dp">

        <View
            android:id="@+id/timeline_bg_line"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_centerVertical="true"
            android:layout_marginHorizontal="30dp"
            android:background="@color/transparent_white_20" />

        <ProgressBar
            android:id="@+id/trip_progress_bar_header"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_centerVertical="true"
            android:layout_marginHorizontal="31dp"
            android:progress="5"
            android:progressDrawable="@drawable/bg_progress_bar" />

        <LinearLayout
            android:id="@+id/dots_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="20dp"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- Planet Dot -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="start"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/dot_planet_header"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginTop="12dp"
                    android:src="@drawable/ic_dot_active" />

                <TextView
                    android:id="@+id/dot_label_planet_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Planets"
                    android:textColor="@color/body"
                    android:textSize="9sp" />
            </LinearLayout>

            <!-- Location Dot -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/dot_location_header"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginTop="12dp"
                    android:src="@drawable/ic_dot_inactive" />

                <TextView
                    android:id="@+id/dot_label_location_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Locations"
                    android:textColor="@color/body"
                    android:textSize="9sp" />
            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>

</RelativeLayout>
