<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="24dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="240dp"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingHorizontal="12dp">

                <TextView
                    android:id="@+id/title_about_fragment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_bold"
                    android:letterSpacing="0.05"
                    android:text="About Astryx"
                    android:textAlignment="center"
                    android:textColor="@color/title"
                    android:textSize="36sp" />

                <TextView
                    android:id="@+id/subtitle_about_fragment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:lineSpacingExtra="2dp"
                    android:text="Leading the future of interplanetary travel since 2026"
                    android:textAlignment="center"
                    android:textColor="@color/subtitle"
                    android:textSize="16sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="240dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:id="@+id/tv_successful_missions_counter"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="500+"
                            android:textAlignment="center"
                            android:textColor="?attr/customColorPrimary"
                            android:textSize="28sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Successful \nMissions"
                            android:textAlignment="center"
                            android:textAllCaps="true"
                            android:textColor="@color/section_title"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:id="@+id/tv_planets_visited_counter"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="8"
                            android:textAlignment="center"
                            android:textColor="?attr/customColorPrimary"
                            android:textSize="28sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Planets \nVisited"
                            android:textAlignment="center"
                            android:textAllCaps="true"
                            android:textColor="@color/section_title"
                            android:textSize="12sp" />

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:id="@+id/tv_happy_travelers_counter"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="10,000+"
                            android:textAlignment="center"
                            android:textColor="?attr/customColorPrimary"
                            android:textSize="28sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Happy \nTravelers"
                            android:textAlignment="center"
                            android:textAllCaps="true"
                            android:textColor="@color/section_title"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:id="@+id/tv_years_in_operation_counter"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="1"
                            android:textAlignment="center"
                            android:textColor="?attr/customColorPrimary"
                            android:textSize="28sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Years in \nOperation"
                            android:textAlignment="center"
                            android:textAllCaps="true"
                            android:textColor="@color/section_title"
                            android:textSize="12sp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_book"
                        app:tint="?attr/customColorPrimary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Our Story"
                        android:textAlignment="textStart"
                        android:textColor="@color/title"
                        android:textSize="30sp" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:lineSpacingExtra="4dp"
                    android:text="Astryx was born from a simple idea: what if planning a journey through space felt as intuitive and exciting as planning a trip on Earth?"
                    android:textColor="@color/body"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:lineSpacingExtra="4dp"
                    android:text="What started as a passion project quickly evolved into a platform designed to bring the wonders of the universe closer to everyone. By combining imagination with structured exploration tools, we aim to transform curiosity into interactive experiences."
                    android:textColor="@color/body"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:lineSpacingExtra="4dp"
                    android:text="Our goal is to make space feel accessible — not just as a concept, but as a destination you can explore, understand, and enjoy."
                    android:textColor="@color/body"
                    android:textSize="14sp" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="240dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="36dp"
                    android:text="Our Values"
                    android:textAlignment="center"
                    android:textColor="@color/title"
                    android:textSize="30sp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/transparent"
                    app:strokeColor="?attr/customColorPrimaryFaded"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="24dp"
                        android:layout_marginVertical="24dp"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <com.google.android.material.button.MaterialButton
                            style="@style/Widget.Material3.Button.IconButton.Filled"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:backgroundTint="?attr/customColorPrimaryVariantFaded"
                            android:padding="16dp"
                            app:cornerRadius="20dp"
                            app:icon="@drawable/ic_sparkles_stars"
                            app:iconSize="36dp"
                            app:iconTint="?attr/customColorPrimaryVariant" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginVertical="12dp"
                            android:text="Innovation"
                            android:textAlignment="center"
                            android:textColor="@color/subtitle"
                            android:textSize="20sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:lineSpacingExtra="2dp"
                            android:text="By continuously experimenting with new ideas, technologies, we aim to create immersive and forward-thinking experiences that push the boundaries of traditional travel planning."
                            android:textAlignment="center"
                            android:textColor="@color/body"
                            android:textSize="14sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="60dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/transparent"
                    app:strokeColor="?attr/customColorPrimaryFaded"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="24dp"
                        android:layout_marginVertical="24dp"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <com.google.android.material.button.MaterialButton
                            style="@style/Widget.Material3.Button.IconButton.Filled"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:backgroundTint="#0d2e3b"
                            android:padding="16dp"
                            app:cornerRadius="20dp"
                            app:icon="@drawable/ic_award"
                            app:iconSize="36dp"
                            app:iconTint="#00d2f2" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginVertical="12dp"
                            android:text="Excellence"
                            android:textAlignment="center"
                            android:textColor="@color/subtitle"
                            android:textSize="20sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:lineSpacingExtra="2dp"
                            android:text="Maintaining the highest standards of safety, comfort, and customer satisfaction in every journey we undertake."
                            android:textAlignment="center"
                            android:textColor="@color/body"
                            android:textSize="14sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="60dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/transparent"
                    app:strokeColor="?attr/customColorPrimaryFaded"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="24dp"
                        android:layout_marginVertical="24dp"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <com.google.android.material.button.MaterialButton
                            style="@style/Widget.Material3.Button.IconButton.Filled"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:backgroundTint="#142440"
                            android:padding="16dp"
                            app:cornerRadius="20dp"
                            app:icon="@drawable/ic_target"
                            app:iconSize="36dp"
                            app:iconTint="#4fa1ff" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginVertical="12dp"
                            android:text="Our Mission"
                            android:textAlignment="center"
                            android:textColor="@color/subtitle"
                            android:textSize="20sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:lineSpacingExtra="2dp"
                            android:text="To make space travel accessible, safe, and transformative for everyone who dreams of exploring beyond Earth."
                            android:textAlignment="center"
                            android:textColor="@color/body"
                            android:textSize="14sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="240dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_users"
                        app:tint="?attr/customColorPrimary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Our Team"
                        android:textColor="@color/title"
                        android:textSize="30sp" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:lineSpacingExtra="4dp"
                    android:text="We are a small team of developers and space enthusiasts united by a shared passion for exploration and technology."
                    android:textColor="@color/body"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:lineSpacingExtra="4dp"
                    android:text="With backgrounds in software development, design, and curiosity-driven learning, we focus on building meaningful digital experiences that inspire users to think beyond the ordinary."
                    android:textColor="@color/body"
                    android:textSize="16sp" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="240dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/footer_icon_about_fragment"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:src="@drawable/ic_rocket"
                    app:tint="?attr/customColorPrimary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Ready to Explore?"
                    android:textAlignment="center"
                    android:textColor="@color/title"
                    android:textSize="30sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:lineSpacingExtra="2dp"
                    android:text="Join thousands of travelers who have already experienced the wonder of space with Astryx."
                    android:textAlignment="center"
                    android:textColor="@color/body"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_book_journey_about_fragment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="36dp"
                    android:background="@drawable/bg_gradient"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="12dp"
                    android:text="Book Your Journey"
                    android:textColor="@color/on_primary"
                    android:textSize="16sp"
                    app:backgroundTint="@null" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="120dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:gravity="center"
                android:text="Astryx v1.0.0"
                android:textColor="@color/body"
                android:textSize="12sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="© 2026 Astryx. All rights reserved."
                android:textColor="@color/body"
                android:textSize="12sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="50dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.appcompat.widget.LinearLayoutCompat>