<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="12dp"
    android:backgroundTint="@color/background"
    app:cardCornerRadius="24dp"
    app:cardElevation="4dp"
    app:strokeColor="?attr/customColorPrimaryFaded">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingVertical="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <View
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_oval_gradient" />

                <com.google.android.material.imageview.ShapeableImageView
                    style="@style/ShapeAppearance.Material3.Corner.Full"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_gravity="center"
                    android:background="@color/background"
                    android:padding="1dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                    app:strokeWidth="0dp" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/user_pic_item_review"
                    android:layout_width="66dp"
                    android:layout_height="66dp"
                    android:layout_gravity="center"
                    android:background="@color/transparent"
                    android:padding="8dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/pic_profile_placeholder" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/reviewer_name_item_review"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Igor Chikati"
                    android:textColor="@color/title"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/review_date_item_review"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="3 days ago"
                    android:textColor="@color/body"
                    android:textSize="14sp" />

            </LinearLayout>

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="top"
                android:layout_marginEnd="2dp"
                android:rotation="180"
                android:src="@drawable/ic_quotation_mark"
                app:tint="?attr/customColorPrimaryFaded" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rating_star_container_item_review"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/star1"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_rating_star_filled"
                app:tint="?attr/customColorPrimary" />

            <ImageView
                android:id="@+id/star2"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_rating_star_filled"
                app:tint="?attr/customColorPrimary" />


            <ImageView
                android:id="@+id/star3"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_rating_star_filled"
                app:tint="?attr/customColorPrimary" />


            <ImageView
                android:id="@+id/star4"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_rating_star_filled"
                app:tint="?attr/customColorPrimary" />


            <ImageView
                android:id="@+id/star5"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_rating_star_filled"
                app:tint="?attr/customColorPrimary" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_primary_light_stroke"
            android:gravity="center"
            android:paddingVertical="3dp"
            android:paddingStart="10dp"
            android:paddingEnd="14dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_pin"
                app:tint="?attr/customColorPrimaryLight" />

            <TextView
                android:id="@+id/destination_title_item_review"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mars"
                android:textColor="?attr/customColorPrimaryLight"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/review_content_item_review"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Incredible experience! The red desert landscape is otherworldly."
            android:textColor="@color/body"
            android:textSize="16sp" />

    </androidx.appcompat.widget.LinearLayoutCompat>

</com.google.android.material.card.MaterialCardView>