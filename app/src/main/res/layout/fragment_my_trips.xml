<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Normal State: Trip List -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/trips_list_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/my_trips_header_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="48dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_primary_light_stroke"
                        android:gravity="center"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="10dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_rocket"
                            app:tint="?attr/customColorPrimaryLight" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="Your Journey"
                            android:textColor="?attr/customColorPrimaryLight"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:lineSpacingExtra="4dp"
                        android:paddingHorizontal="24dp"
                        android:text="Manage your space travel adventures across the cosmos"
                        android:textAlignment="center"
                        android:textColor="@color/subtitle"
                        android:textSize="14sp" />

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/my_trips_help_btn"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="18dp"
                    app:icon="@drawable/ic_help"
                    app:iconSize="28dp"
                    app:iconTint="@color/icon" />

            </RelativeLayout>

            <LinearLayout
                android:id="@+id/draft_trips_container_my_trips_fragment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_primary_light"
                    android:padding="8dp"
                    android:src="@drawable/ic_circle"
                    app:tint="?attr/customColorPrimaryLight" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Draft Trips"
                        android:textColor="@color/title"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ideas and itineraries in progress"
                        android:textColor="@color/body"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/draft_trips_count_my_trips_fragment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_primary_faded"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="3dp"
                    android:text="0 trips"
                    android:textColor="@color/title"
                    android:textSize="12sp" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/draft_trips_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="84dp"
                android:orientation="vertical"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <LinearLayout
                android:id="@+id/planned_trips_container_my_trips_fragment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_primary_light"
                    android:padding="8dp"
                    android:src="@drawable/ic_circle_dot"
                    app:tint="?attr/customColorPrimaryLight" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Planned Trips"
                        android:textColor="@color/title"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Confirmed bookings and upcoming adventures"
                        android:textColor="@color/body"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/planned_trips_count_my_trips_fragment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_primary_faded"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="3dp"
                    android:text="0 trips"
                    android:textColor="@color/title"
                    android:textSize="12sp" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/planned_trips_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="84dp"
                android:orientation="vertical"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <LinearLayout
                android:id="@+id/completed_trips_container_my_trips_fragment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_primary_light"
                    android:padding="8dp"
                    android:src="@drawable/ic_check_circle"
                    app:tint="?attr/customColorPrimaryLight" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Completed Trips"
                        android:textColor="@color/title"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Your cosmic journey history"
                        android:textColor="@color/body"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/completed_trips_count_my_trips_fragment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_primary_faded"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="3dp"
                    android:text="0 trips"
                    android:textColor="@color/title"
                    android:textSize="12sp" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/completed_trips_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="120dp"
                android:orientation="vertical"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/create_trip_btn"
        style="@style/Widget.Material3.Button.IconButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="36dp"
        android:elevation="2dp"
        android:padding="18dp"
        app:backgroundTint="?attr/customColorPrimary"
        app:cornerRadius="18dp"
        app:icon="@drawable/ic_plus"
        app:iconSize="24dp"
        app:iconTint="@color/on_primary" />

    <include
        android:id="@+id/empty_state_layout"
        layout="@layout/layout_empty_state" />

</RelativeLayout>
