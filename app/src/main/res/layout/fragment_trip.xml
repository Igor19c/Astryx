<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginVertical="24dp"
    android:background="@color/background"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:background="@drawable/bg_transparent_stroke_primary">

        <LinearLayout
            android:id="@+id/departure_date_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Departure Date: "
                android:textColor="@color/subtitle"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/trip_departure_date_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="21/02"
                android:textColor="@color/subtitle"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/return_date_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/departure_date_container"
            android:layout_centerVertical="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Return Date: "
                android:textColor="@color/subtitle"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/trip_return_date_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="29/02"
                android:textColor="@color/subtitle"
                android:textSize="16sp" />
        </LinearLayout>


        <com.google.android.material.button.MaterialButton
            android:id="@+id/edit_btn"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:backgroundTint="@color/transparent"
            app:icon="@drawable/ic_edit"
            app:iconSize="22dp"
            app:iconTint="@color/icon" />
    </RelativeLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="12dp"
        android:layout_weight="1">

        <!-- Normal State: Destinations List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/itinerary_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="12dp"
            android:visibility="visible"
            tools:listitem="@layout/item_trip_destination" />

        <!-- Empty State -->
        <include
            android:id="@+id/empty_state_layout"
            layout="@layout/layout_empty_state" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/btn_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="24dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/finalize_btn_trip_item"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginVertical="18dp"
            android:layout_weight="1"
            android:background="@drawable/bg_gradient"
            android:elevation="4dp"
            android:shadowColor="@color/transparent_black_60"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="10"
            android:text="Finalize"
            android:textColor="@color/on_primary"
            android:textSize="14sp"
            app:backgroundTint="@null"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/add_destination_btn"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginVertical="18dp"
            android:layout_weight="1"
            android:backgroundTint="@color/background"
            android:elevation="3dp"
            android:paddingVertical="14dp"
            android:shadowColor="@color/transparent_black_20"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="12"
            android:text="Add"
            android:textColor="@color/secondary_outlined_btn"
            android:textSize="14sp"
            app:cornerRadius="16dp"
            app:strokeColor="@color/secondary_outlined_btn"
            app:strokeWidth="0.8dp" />

    </LinearLayout>

</LinearLayout>
