<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"> <!-- כאן הרווח מהצדדים יקרה באמת -->

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginVertical="24dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Badge Unlocked!"
                android:textColor="@color/achievement"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/dialogBadgeImage"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/dialogBadgeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Explorer"
                android:textColor="@color/deep_black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dialogBadgeDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="You've visited 5 different planets!"
                android:textColor="@color/deep_black"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialogCloseBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:backgroundTint="?attr/customColorPrimary"
                android:text="Awesome!"
                android:textColor="@color/on_primary"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>