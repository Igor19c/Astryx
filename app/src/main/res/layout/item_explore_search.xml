<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardBackgroundColor="@color/background"
    app:cardCornerRadius="24dp"
    app:strokeColor="?attr/customColorPrimaryFaded"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/image_item_explore_search"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:scaleType="centerInside"
                android:src="@drawable/pic_profile_placeholder" />

        </RelativeLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/title_item_explore_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mars"
                android:textColor="@color/title"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/subtitle_item_explore_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="The Red Planet"
                android:textColor="@color/subtitle"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/type_chip_item_explore_search"
                    style="@style/MaterialAlertDialog.Material3.Body.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_gray_stroke"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Planet"
                    android:textColor="@color/chip_stroke"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/difficulty_chip_item_explore_search"
                    style="@style/MaterialAlertDialog.Material3.Body.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_success_stroke"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Beginer"
                    android:textColor="@color/success"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/description_item_explore_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Experience the Red Planet's dramatic landscapes, towering volcanoes, and vast canyons. Walk where rovers have roamed and witness breathtaking Martian sunsets."
                android:textColor="@color/body"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/distance_item_explore_search"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:drawablePadding="6dp"
                    android:gravity="center_vertical"
                    android:text="455 milion km"
                    android:textColor="@color/body"
                    android:textSize="12sp"
                    app:drawableStartCompat="@drawable/ic_distance"
                    app:drawableTint="@color/gray_dark" />


                <TextView
                    android:id="@+id/travel_time_item_explore_search"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:drawablePadding="6dp"
                    android:gravity="center_vertical"
                    android:text="Travel time 147 days"
                    android:textColor="@color/body"
                    android:textSize="12sp"
                    app:drawableSize="8dp"
                    app:drawableStartCompat="@drawable/ic_rocket"
                    app:drawableTint="@color/gray_dark" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Highlights"
                android:textColor="@color/section_title"
                android:textSize="16sp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/dest_tags_chip_group_item_explore_search"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clickable="false"
                app:chipSpacingHorizontal="8dp"
                app:selectionRequired="false">

            </com.google.android.material.chip.ChipGroup>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_view_detail_item_explore_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_weight="1"
                android:background="@drawable/bg_gradient"
                android:letterSpacing="0.1"
                android:text="View Details"
                android:textColor="@color/on_primary"
                android:textSize="14sp"
                android:textStyle="normal"
                app:backgroundTint="@null"
                app:cornerRadius="12dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>