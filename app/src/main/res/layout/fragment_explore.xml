<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginHorizontal="12dp"
    android:background="@color/background"
    android:orientation="vertical"
    android:paddingVertical="10dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/explore_content_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginBottom="12dp"
                android:layout_weight="1">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/carousel_view_pager"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_above="@+id/carousel_indicator" />

                <LinearLayout
                    android:id="@+id/dest_rating_chip_carousel_item"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignBottom="@+id/carousel_view_pager"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_primary_light_stroke"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp">

                    <ImageView
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_rating_star_filled"
                        app:tint="?attr/customColorPrimaryLight" />

                    <TextView
                        android:id="@+id/dest_rating_text_carousel_item"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="4dp"
                        android:text="4.5"
                        android:textColor="?attr/customColorPrimaryLight"
                        android:textSize="14sp" />

                </LinearLayout>

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/carousel_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:layout_alignParentBottom="true"
                    android:layout_centerHorizontal="true"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginVertical="6dp"
                    android:backgroundTint="@color/transparent"
                    app:tabIconTint="@color/dot_tint_selector"
                    app:tabIndicator="@drawable/tab_indicator"
                    app:tabIndicatorAnimationMode="elastic"
                    app:tabIndicatorColor="?attr/customColorPrimary"
                    app:tabIndicatorFullWidth="false"
                    app:tabIndicatorGravity="center"
                    app:tabMaxWidth="80dp"
                    app:tabMinWidth="10dp"
                    app:tabMode="fixed"
                    app:tabRippleColor="@color/transparent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/explore_help_btn"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="6dp"
                    app:icon="@drawable/ic_help"
                    app:iconSize="28dp"
                    app:iconTint="@color/icon" />

            </RelativeLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/dest_details_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:backgroundTint="@color/transparent"
                app:cardCornerRadius="24dp"
                app:strokeColor="?attr/customColorPrimaryFaded"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="12dp"
                    android:paddingBottom="15dp">

                    <LinearLayout
                        android:id="@+id/detail_glass_container_carousel_item"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/dest_title_carousel_item"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="start"
                                android:padding="6dp"
                                android:text="Aurora Observatory Dome"
                                android:textColor="@color/title"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:id="@+id/dest_price_tier_container_carousel_item"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:contentDescription="Price tier"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:padding="4dp"
                                android:paddingVertical="4dp">

                            </LinearLayout>


                        </LinearLayout>


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/dest_subtitle_carousel_item"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="start"
                                android:padding="6dp"
                                android:text="The Red Planet"
                                android:textColor="@color/title"
                                android:textSize="12sp" />

                            <LinearLayout
                                android:id="@+id/dest_safety_lvl_container_carousel_item"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:padding="4dp"
                                android:paddingVertical="4dp">

                            </LinearLayout>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:id="@+id/dest_travel_time_container_carousel_item"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:padding="6dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:gravity="start"
                                    android:text="Travel time: "
                                    android:textColor="@color/title"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/dest_travel_time_text_carousel_item"
                                    android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:gravity="start"
                                    android:textColor="@color/title"
                                    android:textSize="12sp" />

                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/dest_difficulty_container_carousel_item"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:gravity="start"
                                android:orientation="horizontal"
                                android:padding="4dp">

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="18dp">


                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/detailsBtn"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:layout_weight="1"
                            android:backgroundTint="@color/transparent"
                            android:text="View Details"
                            android:textAllCaps="false"
                            android:textColor="@color/secondary"
                            android:textSize="14sp"
                            app:cornerRadius="12dp"
                            app:strokeColor="@color/secondary_outlined_btn"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/selectBtn"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:backgroundTint="@color/secondary_filled_btn"
                            android:text="Explore"
                            android:textAllCaps="false"
                            android:textColor="@color/on_secondary_filled_btn"
                            android:textSize="14sp"
                            app:cornerRadius="12dp" />
                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </FrameLayout>

</androidx.appcompat.widget.LinearLayoutCompat>
