<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:backgroundTint="@color/background"
    app:cardCornerRadius="12dp"
    app:strokeColor="?attr/customColorPrimaryFaded"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/hazard_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hazard Name"
                android:textColor="@color/title"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/hazard_stars_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/dest_hazard_lvl_icon_1"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_hazard"
                    app:tint="@color/alert" />

                <ImageView
                    android:id="@+id/dest_hazard_lvl_icon_2"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_hazard"
                    app:tint="@color/alert" />

                <ImageView
                    android:id="@+id/dest_hazard_lvl_icon_3"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_hazard"
                    app:tint="@color/alert_faded" />

                <ImageView
                    android:id="@+id/dest_hazard_lvl_icon_4"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_hazard"
                    app:tint="@color/alert_faded" />

                <ImageView
                    android:id="@+id/dest_hazard_lvl_icon_5"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_hazard"
                    app:tint="@color/alert_faded" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/hazard_tip_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:clickable="true"
            android:focusable="true"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tip"
                android:textColor="?attr/customColorPrimaryLight"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/hazard_tip_arrow"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginHorizontal="8dp"
                android:layout_marginTop="5dp"
                android:src="@drawable/ic_arrow_right"
                app:tint="?attr/customColorPrimaryLight" />

            <TextView
                android:id="@+id/hazard_tip_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Safety tip goes here..."
                android:textColor="@color/body"
                android:textSize="14sp"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
