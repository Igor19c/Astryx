<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/post_settings_btn_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/transparent_black_80"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/customColorPrimaryFaded"
    app:strokeWidth="2dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/delete_btn_post_item"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:text="Delete"
            android:textColor="@color/alert"
            android:textSize="16sp"
            app:icon="@drawable/ic_trash"
            app:iconTint="@color/alert" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/edit_btn_post_item"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:text="Edit"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:icon="@drawable/ic_edit"
            app:iconTint="@color/white" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>