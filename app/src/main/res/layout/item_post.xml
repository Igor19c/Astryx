<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="6dp"
    android:layout_marginVertical="24dp"
    android:background="@color/background"
    android:clickable="true"
    android:focusable="true">


    <LinearLayout
        android:id="@+id/post_header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/user_profile_image_post_item"
            style="@style/ShapeAppearance.Material3.Corner.Full"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center_vertical"
            android:src="@drawable/pic_profile_placeholder" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/user_name_post_item"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignStart="@+id/settings_btn_post_item"
                    android:layout_alignParentStart="true"
                    android:layout_marginTop="8dp"
                    android:text="User Name"
                    android:textColor="@color/title"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/settings_btn_post_item"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    app:icon="@drawable/ic_dots"
                    app:iconSize="30dp"
                    app:iconTint="@color/icon" />

            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:gravity="top"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/trip_title_post_item"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Trip Title"
                    android:textColor="@color/subtitle"
                    android:textSize="14sp" />

                <LinearLayout
                    android:id="@+id/rating_star_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/rating_star_01_post_item"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_rating_star_filled" />

                    <ImageView
                        android:id="@+id/rating_star_02_post_item"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_rating_star_filled" />

                    <ImageView
                        android:id="@+id/rating_star_03_post_item"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_rating_star_filled" />

                    <ImageView
                        android:id="@+id/rating_star_04_post_item"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_rating_star_filled" />

                    <ImageView
                        android:id="@+id/rating_star_05_post_item"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_rating_star_filled" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <RelativeLayout
        android:id="@+id/post_image_container"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@+id/post_header_container">

        <ImageView
            android:id="@+id/image_post_item"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/background"
            android:clickable="true"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_home_earth" />

    </RelativeLayout>

    <LinearLayout
        android:id="@+id/post_footer_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/post_image_container">


        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/like_btn_post_item"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_star_outlined"
                app:icon="@drawable/ic_star_outlined"
                app:iconSize="28dp"
                app:iconTint="?attr/customColorPrimary" />

            <TextView
                android:id="@+id/like_counter_post_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="47"
                android:textColor="@color/title"
                android:textSize="18sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/description_post_item"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginTop="6dp"
            android:text="The sunrise on Mars is absolutely breathtaking! Blue hues dancing across the red landscape. A must-visit!"
            android:textColor="@color/body"
            android:textSize="14sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>