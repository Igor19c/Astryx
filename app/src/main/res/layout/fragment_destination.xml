<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/dest_app_bar"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:background="@color/transparent">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:contentScrim="@color/background"
            app:layout_scrollFlags="scroll|exitUntilCollapsed">

            <ImageView
                android:id="@+id/dest_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_home_earth"
                app:layout_collapseMode="parallax" />

            <View
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_gravity="bottom" />

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/dest_toolbar_header"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:layout_marginTop="18dp"
                app:layout_collapseMode="pin">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/dest_back_btn"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/transparent"
                    app:icon="@drawable/ic_back"
                    app:iconSize="30dp"
                    app:iconTint="@color/icon" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/dest_save_destination_btn"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginEnd="10dp"
                    app:backgroundTint="@color/transparent"
                    app:icon="@drawable/ic_star_outlined"
                    app:iconSize="30dp"
                    app:iconTint="@color/icon" />
            </androidx.appcompat.widget.Toolbar>

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/dest_title_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="12dp"
                    android:layout_weight="1"
                    android:text="Mars"
                    android:textColor="@color/title"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/dest_rating_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_primary_light_stroke"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp">

                    <ImageView
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_rating_star_filled"
                        app:tint="?attr/customColorPrimaryLight" />

                    <TextView
                        android:id="@+id/dest_rating_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="4dp"
                        android:text="4.5"
                        android:textColor="?attr/customColorPrimaryLight"
                        android:textSize="14sp" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="5dp">

                <TextView
                    android:id="@+id/dest_subtitle_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:layout_weight="1"
                    android:text="The Red Planet"
                    android:textColor="?attr/customColorPrimaryLight"
                    android:textSize="16sp" />

                <LinearLayout
                    android:id="@+id/dest_price_tier_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="Price tier"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/dest_price_tier_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="Price tier"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="4dp"
                        android:paddingVertical="4dp">

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Short Description Section -->
            <TextView
                android:id="@+id/dest_short_description_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="6dp"
                android:text="Short description here..."
                android:textColor="@color/body"
                android:textSize="15sp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/dest_tags_chip_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="4dp">

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Adventure"
                    android:textColor="@color/body"
                    android:textSize="8sp"
                    app:chipBackgroundColor="@color/transparent_black_80"
                    app:chipCornerRadius="10dp"
                    app:chipStrokeColor="@color/transparent_white_20" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Adventure"
                    android:textColor="@color/body"
                    android:textSize="8sp"
                    app:chipBackgroundColor="@color/transparent_black_80"
                    app:chipCornerRadius="10dp"
                    app:chipStrokeColor="@color/transparent_white_20" />

            </com.google.android.material.chip.ChipGroup>

            <!-- Long Description Section -->
            <TextView
                android:id="@+id/dest_long_description_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:lineSpacingExtra="6dp"
                android:text="Long description here..."
                android:textColor="@color/body"
                android:textSize="15sp" />

            <!-- Best Time to Visit Section -->
            <LinearLayout
                android:id="@+id/dest_best_time_to_visit_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Best time to visit:"
                    android:textColor="@color/title"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/dest_best_time_to_visit_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="6dp"
                    android:text="Best time to visit..."
                    android:textColor="@color/body"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- Children Section -->
            <LinearLayout
                android:id="@+id/dest_children_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/dest_children_title_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:text="Mars destination"
                    android:textColor="@color/title"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/dest_children_recycle_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
            </LinearLayout>

            <!-- Tab Section -->
            <LinearLayout
                android:id="@+id/dest_tab_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp"
                android:orientation="vertical">

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/dest_tab_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@color/transparent"
                    app:tabIndicatorColor="?attr/customColorPrimary"
                    app:tabMode="fixed"
                    app:tabSelectedTextColor="@color/title"
                    app:tabTextColor="@color/body">

                    <com.google.android.material.tabs.TabItem
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="5dp"
                        android:text="Highlights" />

                    <com.google.android.material.tabs.TabItem
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="5dp"
                        android:text="Environment" />

                    <com.google.android.material.tabs.TabItem
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Safety" />

                </com.google.android.material.tabs.TabLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="10dp">

                    <LinearLayout
                        android:id="@+id/dest_highlights_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <LinearLayout
                            android:id="@+id/dest_highlights_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="vertical" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/dest_environment_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TableLayout
                            android:id="@+id/dest_environment_table"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:stretchColumns="1">

                            <!-- Row 1: Atmosphere -->
                            <TableRow
                                android:layout_marginBottom="8dp"
                                android:background="@drawable/bg_transparent_stroke_primary"
                                android:paddingVertical="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="12dp"
                                    android:text="Atmosphere"
                                    android:textColor="@color/body"
                                    android:textSize="14sp" />

                                <TextView
                                    android:id="@+id/env_atmosphere_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="12dp"
                                    android:gravity="end"
                                    android:text="Breathable"
                                    android:textColor="@color/title"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </TableRow>

                            <!-- Row 2: Gravity -->
                            <TableRow
                                android:layout_marginBottom="8dp"
                                android:background="@drawable/bg_transparent_stroke_primary"
                                android:paddingVertical="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="12dp"
                                    android:text="Gravity"
                                    android:textColor="@color/body"
                                    android:textSize="14sp" />

                                <TextView
                                    android:id="@+id/env_gravity_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="12dp"
                                    android:gravity="end"
                                    android:text="1.0 G"
                                    android:textColor="@color/title"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </TableRow>

                            <!-- Row 3: Temperature -->
                            <TableRow
                                android:layout_marginBottom="8dp"
                                android:background="@drawable/bg_transparent_stroke_primary"
                                android:paddingVertical="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="12dp"
                                    android:text="Temperature"
                                    android:textColor="@color/body"
                                    android:textSize="14sp" />

                                <TextView
                                    android:id="@+id/env_temp_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="12dp"
                                    android:gravity="end"
                                    android:text="-10°C to 35°C"
                                    android:textColor="@color/title"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </TableRow>

                            <!-- Row 4: Radiation -->
                            <TableRow
                                android:layout_marginBottom="8dp"
                                android:background="@drawable/bg_transparent_stroke_primary"
                                android:paddingVertical="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="12dp"
                                    android:text="Radiation"
                                    android:textColor="@color/body"
                                    android:textSize="14sp" />

                                <TextView
                                    android:id="@+id/env_radiation_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="12dp"
                                    android:gravity="end"
                                    android:text="Low"
                                    android:textColor="@color/title"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </TableRow>

                            <!-- Row 5: Day Length -->
                            <TableRow
                                android:layout_marginBottom="8dp"
                                android:background="@drawable/bg_transparent_stroke_primary"
                                android:paddingVertical="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="12dp"
                                    android:text="Day Length"
                                    android:textColor="@color/body"
                                    android:textSize="14sp" />

                                <TextView
                                    android:id="@+id/env_day_length_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="12dp"
                                    android:gravity="end"
                                    android:text="24h"
                                    android:textColor="@color/title"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </TableRow>

                            <!-- Row 6: Visibility -->
                            <TableRow
                                android:background="@drawable/bg_transparent_stroke_primary"
                                android:paddingVertical="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="12dp"
                                    android:text="Visibility"
                                    android:textColor="@color/body"
                                    android:textSize="14sp" />

                                <TextView
                                    android:id="@+id/env_visibility_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="12dp"
                                    android:gravity="end"
                                    android:text="High"
                                    android:textColor="@color/title"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </TableRow>
                        </TableLayout>

                    </LinearLayout>


                    <LinearLayout
                        android:id="@+id/dest_safety_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:id="@+id/dest_safety_notes_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:text="Hazards:"
                            android:textColor="@color/title"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/dest_hazards_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="vertical" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="120dp"
                android:backgroundTint="@color/background"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/customColorPrimaryFaded"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="Rate your Experience"
                        android:textColor="@color/title"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="4dp"
                        android:text="How was your stay at this destination?"
                        android:textColor="@color/body"
                        android:textSize="14sp" />

                    <RatingBar
                        android:id="@+id/dest_review_rating_bar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="20dp"
                        android:numStars="5"
                        android:progressBackgroundTint="?attr/customColorPrimaryLightFaded"
                        android:progressTint="?attr/customColorPrimary"
                        android:rating="4"
                        android:stepSize="1" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/dest_edit_review_field"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="18dp"
                        android:layout_marginTop="20dp"
                        android:hint="Tell us more (optional)"
                        android:textColorHint="@color/body"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxStrokeColor="@color/text_input_stroke"
                        app:cursorColor="?attr/customColorPrimary"
                        app:hintTextColor="@color/body">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/dest_edit_review_content"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="top"
                            android:inputType="textMultiLine"
                            android:minLines="3"
                            android:textColor="@color/title"
                            android:textColorHint="@color/body" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="12dp"
                        android:layout_marginTop="24dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/dest_clear_review_btn"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Clear"
                            android:textAllCaps="false"
                            android:textColor="@color/secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/dest_submit_review_btn"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:backgroundTint="?attr/customColorPrimary"
                            android:text="Submit"
                            android:textColor="@color/on_primary"
                            app:cornerRadius="12dp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:text="Traveler Experiences"
                    android:textAlignment="center"
                    android:textColor="@color/title"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="12dp"
                    android:gravity="center_horizontal"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/dest_rating_star_container_dest_fragment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/rating_star_01_dest_fragment"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_rating_star_filled" />

                        <ImageView
                            android:id="@+id/rating_star_02_dest_fragment"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_rating_star_filled" />

                        <ImageView
                            android:id="@+id/rating_star_03_dest_fragment"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_rating_star_filled" />

                        <ImageView
                            android:id="@+id/rating_star_04_dest_fragment"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_rating_star_filled" />

                        <ImageView
                            android:id="@+id/rating_star_05_dest_fragment"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_rating_star_filled" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/dest_avg_rating_dest_fragment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_marginHorizontal="12dp"
                        android:text="4.7"
                        android:textColor="@color/title"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/dest_review_count_dest_fragment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:layout_marginStart="12dp"
                        android:layout_marginBottom="2dp"
                        android:text="10,643 reviews"
                        android:textColor="@color/body"
                        android:textSize="14sp" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/reviews_recycler_view_dest_fragment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="24dp"
                    android:orientation="vertical"
                    tools:listitem="@layout/item_review" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="220dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Bar -->
    <LinearLayout
        android:id="@+id/dest_bottom_btn_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/background"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:paddingVertical="20dp">

